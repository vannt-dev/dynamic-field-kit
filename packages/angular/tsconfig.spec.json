{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist-spec",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false
  },
  "include": ["test/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-spec", "examples", "src"]
}
